# =============================================================================
# LightRAG Sidecar — Environment Variables
# =============================================================================
# Copy to .env.lightrag and fill in real values.
#
# Usage with docker-compose overlay:
#   docker compose -f docker-compose.prod.yml -f docker-compose.lightrag.yml \
#     --env-file docker/.env.prod --env-file .env.lightrag up -d --build
# =============================================================================

# ---- Host Port Mapping ------------------------------------------------------
# Container always listens on 8001; this controls the host port.
# Default: 9621 (avoids conflict with NFM API host:8001)
LIGHTRAG_HOST_PORT=9621

# ---- PostgreSQL Connection ---------------------------------------------------
# Defaults inherit from docker/.env.prod if not set here.
# Override to point to a different database for the RAG index.
# LIGHTRAG_PG_HOST=nucpot-prod-db
# LIGHTRAG_PG_PORT=5432
# LIGHTRAG_PG_USER=nfm
# LIGHTRAG_PG_PASSWORD=<same as PROD_POSTGRES_PASSWORD>
# LIGHTRAG_PG_DB=nfm_db
LIGHTRAG_PG_MAX_CONNECTIONS=25

# ---- Vector Index Configuration --------------------------------------------
# Options: HNSW (recommended), HNSW_HALFVEC, IVFFlat, VCHORDRQ
LIGHTRAG_PG_VECTOR_INDEX_TYPE=HNSW

# ---- LLM Configuration -----------------------------------------------------
# Required for query and indexing operations.
# Supports: openai, ollama, and other providers via LightRAG bindings.
LIGHTRAG_LLM_BINDING=openai
LIGHTRAG_LLM_MODEL=gpt-4o-mini

# OpenAI-compatible endpoint (set empty for official OpenAI)
LIGHTRAG_LLM_HOST=

# API key for the LLM provider
# ⚠️  NEVER commit real keys. Use secrets manager in production.
LIGHTRAG_LLM_API_KEY=

# LLM request timeout in seconds
LIGHTRAG_LLM_TIMEOUT=150

# Maximum concurrent LLM operations
LIGHTRAG_MAX_ASYNC_LLM=4

# ---- Local Ollama Configuration --------------------------------------------
# When using a local Ollama LLM via the OpenAI-compatible endpoint, the
# model inference is significantly slower than cloud APIs. Recommended:
#
#   LIGHTRAG_LLM_TIMEOUT=600        # 10 minutes per LLM call
#   LIGHTRAG_MAX_ASYNC_LLM=1       # Mac GPU has limited VRAM
#
# Model selection matters. Small thinking models (e.g. qwen3.5:4b-nvfp4)
# drain their entire context budget on internal reasoning for LightRAG's
# 12k-token ontology-extraction prompts, causing 480s+ timeouts. Prefer
# non-thinking coding variants (e.g. qwen3.6:35b-a3b-coding-nvfp4) which
# emit content strings directly when reasoning_effort is set to "none".
#
# See docker-compose.override.yml for a working local Ollama setup.

# ---- Embedding Configuration -----------------------------------------------
# ⚠️  CRITICAL: The embedding model is FINAL after the first index build.
#    Changing EMBEDDING_MODEL requires a complete rebuild of the RAG index.
#    bge-m3 (1024-dim) is selected for multilingual + Chinese paper support.
LIGHTRAG_EMBEDDING_BINDING=openai
LIGHTRAG_EMBEDDING_MODEL=BAAI/bge-m3
LIGHTRAG_EMBEDDING_DIM=1024

# Embedding API endpoint (if using a custom/vectordb-hosted embedding service)
LIGHTRAG_EMBEDDING_HOST=
LIGHTRAG_EMBEDDING_API_KEY=

# ---- RAG Configuration -----------------------------------------------------
# Summary language for paper indexing. Chinese for Chinese literature support.
LIGHTRAG_SUMMARY_LANGUAGE=Chinese

# ---- Authentication (optional) ----------------------------------------------
# Set to enable API key authentication on the sidecar endpoints.
# If empty, the sidecar is open (suitable for internal network only).
LIGHTRAG_API_KEY=
