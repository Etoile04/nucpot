# Supabase
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Or use direct PostgreSQL connection
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# KIM API (optional, for KIM-based potentials)
# source ~/.local/kim-api/bin/kim-api-activate before starting

# Grading thresholds
GRADING_THRESHOLD_A=0.01
GRADING_THRESHOLD_B=0.03
GRADING_THRESHOLD_C=0.05
GRADING_THRESHOLD_D=0.10
