# NucPot Verify Service Environment
# Copy to .env and fill in values

# Supabase
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Redis (for future Celery support)
REDIS_URL=redis://localhost:6379

# Calculation settings
CALCULATION_TIMEOUT=300
MAX_ATOMS=10000

# Grading thresholds (relative error)
# GRADE_A_THRESHOLD=0.01
# GRADE_B_THRESHOLD=0.03
# GRADE_C_THRESHOLD=0.05
# GRADE_D_THRESHOLD=0.10

# Logging
LOG_LEVEL=INFO
