# Production Environment Configuration for NFMD Web App
#
# This file contains production-specific environment variables for the Next.js frontend.
# DO NOT commit actual production secrets to version control.

# =============================================================================
# Application Configuration
# =============================================================================
# Server-side only: backend URL for Next.js rewrite proxy.
# NOT exposed to client-side JavaScript (no NEXT_PUBLIC_ prefix).
#
# In Docker production, nginx already proxies /api/* to the backend, so
# this rewrite is optional.  Only needed for local development.
#
# ⚠️ NEVER set this to the public domain (e.g. https://nucpot.dpdns.org).
#    That creates an infinite loop: Next.js → domain → nginx → Next.js.
#
# Docker deployment:  API_SERVER_URL=http://nucpot-prod-api:8000  (optional, nginx handles /api/*)
# Vercel preview:     Do NOT set (nginx on the host handles /api/* routing)
API_SERVER_URL=http://nucpot-prod-api:8000
NEXT_PUBLIC_APP_URL=https://nucpot.dpdns.org
NEXT_PUBLIC_SITE_NAME=Nuclear Fuel & Materials Database
NEXT_PUBLIC_SITE_DESCRIPTION=Nuclear Fuel and Materials Properties Database

# =============================================================================
# Analytics & Telemetry
# =============================================================================
NEXT_PUBLIC_GA_ID=${GA_ID}  # Google Analytics ID (if using)
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# =============================================================================
# Feature Flags
# =============================================================================
NEXT_PUBLIC_FEATURE_BLOG_ENABLED=true
NEXT_PUBLIC_FEATURE_ONTOLOGY_ENABLED=true
NEXT_PUBLIC_FEATURE_MD_VERIFICATION_ENABLED=true
NEXT_PUBLIC_FEATURE_USER_REGISTRATION=false  # Disable user registration

# =============================================================================
# HPC Integration Configuration
# =============================================================================
NEXT_PUBLIC_HPC_INTEGRATION_ENABLED=true
NEXT_PUBLIC_HPC_PRIMARY_CLUSTER_NAME=广州星逸集群
NEXT_PUBLIC_HPC_BACKUP_CLUSTER_NAME=天津备份集群

# =============================================================================
# UI Configuration
# =============================================================================
NEXT_PUBLIC_THEME=default
NEXT_PUBLIC_DEFAULT_LANGUAGE=zh

# =============================================================================
# Performance Configuration
# =============================================================================
NEXT_PUBLIC_IMAGE_QUALITY=85
NEXT_PUBLIC_IMAGE_FORMATS=webp,avif,jpg,png

# =============================================================================
# Monitoring Configuration
# =============================================================================
NEXT_PUBLIC_SENTRY_DSN=${SENTRY_DSN}
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# Security Configuration
# =============================================================================
NEXT_PUBLIC_CSRF_TOKEN=${CSRF_TOKEN}  # CSRF token for forms

# =============================================================================
# Content Security
# =============================================================================
NEXT_PUBLIC_CONTENT_SECURITY_POLICY="default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://nucpot.dpdns.org https://api.openai.com"

# =============================================================================
# Maintenance Mode
# =============================================================================
NEXT_PUBLIC_MAINTENANCE_MODE=false
NEXT_PUBLIC_MAINTENANCE_MESSAGE="系统维护中，请稍后再试"
