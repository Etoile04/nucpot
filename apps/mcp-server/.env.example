# ── NFM MCP Server ──────────────────────────────────────────────
# Copy to .env and adjust for your environment.

# Database (async PostgreSQL via asyncpg)
NFM_MCP_DATABASE_URL=postgresql+asyncpg://nfm:nfm@localhost:5432/nfm
NFM_MCP_DATABASE_POOL_SIZE=5
NFM_MCP_DATABASE_POOL_TIMEOUT=30.0

# Fallback REST API
NFM_MCP_API_BASE_URL=http://localhost:8000/v1
NFM_MCP_API_TIMEOUT=30.0

# Knowledge-graph micro-service
NFM_MCP_KG_SERVICE_URL=http://localhost:8001

# Transport: stdio | streamable_http | sse
NFM_MCP_TRANSPORT=stdio
NFM_MCP_HOST=127.0.0.1
NFM_MCP_PORT=8002

# Logging
NFM_MCP_LOG_LEVEL=INFO

# LLM extraction service
NFM_MCP_LLM_SERVICE_URL=http://localhost:8003
