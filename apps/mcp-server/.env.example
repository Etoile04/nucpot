# ── Zotero API credentials ──────────────────────────────────────────────────
# Get your API key at https://www.zotero.org/settings/keys
ZOTERO_API_KEY=your-zotero-api-key

# Your Zotero user ID (visible at https://www.zotero.org/settings/keys)
ZOTERO_USER_ID=your-user-id

# "user" for personal library, "group" for a group library
ZOTERO_LIB_TYPE=user

# ── ChromaDB semantic search ────────────────────────────────────────────────
# Directory for persistent ChromaDB storage
CHROMA_PERSIST_DIR=data/chroma

# Sentence-transformers model for embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── NFM Database ────────────────────────────────────────────────────────────
NFM_DATABASE_URL=postgresql+asyncpg://nfm:nfm@localhost:5432/nfm_db
