# Production Environment Configuration
#
# This file contains production-specific environment variables for the NFMD system.
# DO NOT commit actual production secrets to version control.
# Use environment-specific secret management (e.g., AWS Secrets Manager, Vault).

# =============================================================================
# API Configuration
# =============================================================================
NEXT_PUBLIC_API_URL=https://nucpot.dpdns.org/api
NEXT_PUBLIC_APP_URL=https://nucpot.dpdns.org
NEXT_PUBLIC_SITE_NAME=Nuclear Fuel & Materials Database

# =============================================================================
# Database Configuration (Production PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://nucprod_user:${DB_PASSWORD}@prod-db-postgres.nucpot.internal:5432/nucpot
DATABASE_POOL_SIZE=20
DATABASE_POOL_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# =============================================================================
# Redis Configuration (Production)
# =============================================================================
REDIS_URL=redis://prod-redis.nucpot.internal:6379/0
REDIS_POOL_SIZE=10
CELERY_BROKER_URL=redis://prod-redis.nucpot.internal:6379/0

# =============================================================================
# HPC Cluster Configuration (Production)
# =============================================================================
HPC_SSH_KEY_PATH=/run/secrets/hpc_ssh_key
HPC_PRIMARY_HOST=xylogin1.gznet.ac.cn
HPC_PRIMARY_USER=npic_dsun
HPC_BACKUP_HOST=tjlogin1.tjnet.ac.cn
HPC_BACKUP_USER=npic_dsun
HPC_WORK_DIR=/home/npic_dsun/nucpot/jobs

# HPC Queue Configuration
HPC_QUEUE_NAME=normal
HPC_PARTITION=normal
HCP_QOS=normal

# =============================================================================
# Authentication & Security
# =============================================================================
SECRET_KEY=${SECRET_KEY}  # Generate with: openssl rand -hex 32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Password hashing
PASSLIB_ROUNDS=12

# =============================================================================
# Celery Configuration (Production)
# =============================================================================
CELERY_CONCURRENCY=4
CELERY_PREFETCH_MULTIPLIER=4
CELERY_ACKS_LATE=True
CELERY_TASK_TRACK_STARTED=True
CELERY_TASK_TIME_LIMIT=3600  # 1 hour
CELERY_TASK_SOFT_TIME_LIMIT=3000  # 50 minutes
CELERY_WORKER_PREFETCH_MULTIPLIER=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

# =============================================================================
# Logging Configuration (Production)
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_FILE_PATH=/var/log/nucpot/api/app.log
LOG_ROTATION=true
LOG_ROTATION_SIZE=100MB
LOG_ROTATION_BACKUPS=10
LOG_RETENTION_DAYS=30

# =============================================================================
# Monitoring & Observability
# =============================================================================
SENTRY_DSN=${SENTRY_DSN}  # Sentry DSN for error tracking
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Prometheus metrics
PROMETHEUS_METRICS_ENABLED=true
PROMETHEUS_PORT=9090

# =============================================================================
# CORS Configuration (Production)
# =============================================================================
ALLOWED_ORIGINS=https://nucpot.dpdns.org,https://www.nucpot.org
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# File Upload Configuration
# =============================================================================
MAX_UPLOAD_SIZE=10485760  # 10MB
ALLOWED_FILE_TYPES=.empirical,.setfl,.cif,.xyz,.json
UPLOAD_DIR=/data/uploads

# =============================================================================
# Email Configuration (Optional - for notifications)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=${SMTP_USER}
SMTP_PASSWORD=${SMTP_PASSWORD}
EMAIL_FROM=noreply@nucpot.dpdns.org
EMAIL_TO=admin@nucpot.org

# =============================================================================
# Backup Configuration
# =============================================================================
BACKUP_ENABLED=true
BACKUP_S3_BUCKET=nucpot-backups
BACKUP_RETENTION_DAYS=90
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM

# =============================================================================
# Feature Flags
# =============================================================================
FEATURE_HPC_INTEGRATION=true
FEATURE_ANALYTICS_ENABLED=true
FEATURE_USER_MANAGEMENT=true
FEATURE_BLOG_ENABLED=true

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# =============================================================================
# Cache Configuration
# =============================================================================
CACHE_TTL=3600  # 1 hour
CACHE_MAX_SIZE=1000

# =============================================================================
# Session Configuration
# =============================================================================
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_HTTPONLY=true
SESSION_MAX_AGE=604800  # 7 days

# =============================================================================
# Maintenance Mode
# =============================================================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="系统维护中，请稍后再试 / System under maintenance, please try again later"
