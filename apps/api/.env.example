# Backend environment variables
NFM_DATABASE_URL=postgresql+asyncpg://nfm:nfm@localhost:5432/nfm_db
NFM_DEBUG=true

# Global rate limiting (NFM-1087)
# Applied to all /api/ routes except /api/v1/health.
# Slowapi string format: <count>/<period> where period is second/minute/hour/day.
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_BURST=20/second
RATE_LIMIT_STORAGE_URI=memory://
