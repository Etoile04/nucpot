# Backend environment variables
NFM_DATABASE_URL=postgresql+asyncpg://nfm:nfm@localhost:5432/nfm_db
NFM_DEBUG=true

# VLM (Vision Language Model) for figure extraction (NFM-851)
VLM_PROVIDER=openai
VLM_MODEL=gpt-4o
VLM_API_KEY=
VLM_BASE_URL=https://api.openai.com/v1
VLM_STUB_MODE=false
VLM_OCR_TESSERACT=false

# LightRAG sidecar service (NFM-862)
NFM_LIGHTRAG_HOST=localhost
NFM_LIGHTRAG_PORT=9621
