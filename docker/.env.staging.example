# =============================================================================
# NFM-DB — Staging environment template (NFM-111)
# =============================================================================
# Copy to docker/.env.staging and fill in real values BEFORE the first deploy:
#   cp docker/.env.staging.example docker/.env.staging
#   # edit docker/.env.staging
#   ./scripts/staging_deploy.sh deploy
#
# docker/.env.staging is git-ignored. NEVER commit real secrets.
# Consumed by docker-compose.staging.yml via scripts/staging_deploy.sh.
# Full reference: docs/deployment/staging-pipeline.md
# =============================================================================

# ---- Image tag (roll forward/back; defaults to "latest") --------------------
# Tag for nucpot-staging-api / nucpot-staging-web images. Bump it (e.g.
# 2026.06.13-1) for tagged rollouts and to enable rollback to a prior tag.
STAGING_IMAGE_TAG=latest

# ---- Host port mapping ------------------------------------------------------
# NFM-112 contract: staging API on 127.0.0.1:8001, web on 3000.
STAGING_API_HOST_PORT=8001
STAGING_WEB_HOST_PORT=3000
STAGING_DB_HOST_PORT=5432

# ---- Secrets (REQUIRED — generate strong values) ----------------------------
# Generate e.g.: openssl rand -hex 32
STAGING_API_SECRET_KEY=change-me-generate-a-strong-secret
# Generate e.g.: openssl rand -hex 24  (used by the bundled PG16 container)
STAGING_POSTGRES_PASSWORD=change-me-generate-a-strong-password

# ---- Bundled PostgreSQL 16 --------------------------------------------------
STAGING_POSTGRES_USER=nfm
STAGING_POSTGRES_DB=nfm_db
# Default DATABASE_URL points the API at the bundled PG16 container. The NFM-DB
# API uses asyncpg. alembic reads this same URL to run migrations on startup.
STAGING_DATABASE_URL=postgresql+asyncpg://nfm:change-me-generate-a-strong-password@nucpot-staging-db:5432/nfm_db

# ---- CORS / public origins --------------------------------------------------
# JSON array (pydantic-settings parses lists as JSON). Use the staging web origin.
STAGING_CORS_ORIGINS=["https://staging.nucpot.dpdns.org"]

# ---- Misc -------------------------------------------------------------------
STAGING_DEBUG=false
STAGING_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---- Health gate (deploy script) --------------------------------------------
STAGING_HEALTH_PATH=/api/v1/health
STAGING_HEALTH_TIMEOUT=120
STAGING_ROLLBACK_TAG=prev
