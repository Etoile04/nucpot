# =============================================================================
# NFM / NucPot — Staging environment configuration (template)
# =============================================================================
# Copy to "docker/.env.staging" and fill in real values:
#     cp docker/.env.staging.example docker/.env.staging
#     $EDITOR docker/.env.staging
#
# NEVER commit "docker/.env.staging". It is gitignored. This template holds
# non-secret defaults and clearly-marked placeholders for secrets.
#
# Provision real secrets via the GitHub "staging" environment or directly in
# the host's docker/.env.staging. See docs/deployment/staging-pipeline.md.
# =============================================================================

# --- Runtime environment -----------------------------------------------------
# Locked to staging. The stack forces APP_ENV=staging in compose regardless.
APP_ENV=staging
NFM_DEBUG=false

# --- Public staging URLs (Cloudflare tunnel ingresses) -----------------------
# Used by the health gate (staging_deploy.sh) and smoke tests.
STAGING_WEB_URL=https://staging.nucpot.dpdns.org
STAGING_API_URL=https://staging-api.nucpot.dpdns.org

# --- PostgreSQL (staging) ----------------------------------------------------
# Host is the compose service name "postgres" (in-container). The same
# POSTGRES_PASSWORD is used for both server bootstrap and the app DSN.
POSTGRES_USER=nfm
POSTGRES_PASSWORD=CHANGE_ME_STAGING_DB_PASSWORD
POSTGRES_DB=nfm_db
NFM_DATABASE_URL=postgresql+asyncpg://nfm:CHANGE_ME_STAGING_DB_PASSWORD@postgres:5432/nfm_db

# --- Redis / cache (staging) -------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Object storage (staging) ------------------------------------------------
# Alibaba Cloud OSS (S3-compatible). Separate bucket from production.
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=nfm-staging
OSS_ACCESS_KEY_ID=CHANGE_ME_STAGING_OSS_KEY
OSS_ACCESS_KEY_SECRET=CHANGE_ME_STAGING_OSS_SECRET

# --- Image registry (optional) ----------------------------------------------
# When set, the stack pulls these pre-built images instead of building from
# source. Leave blank to build locally (default for host-side first deploys).
# Versioned tags (e.g. ghcr.io/etoile04/nucpot-api:staging-<sha>) enable
# reliable rollback; see scripts/staging_deploy.sh.
NFM_API_IMAGE=
NFM_WEB_IMAGE=

# --- Secrets (provision out-of-band) ----------------------------------------
# Cloudflare Zero Trust tunnel token for staging.nucpot.dpdns.org.
STAGING_CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME_CLOUDFLARE_TUNNEL_TOKEN
# GitHub PAT with write:packages. Only required when publishing images to GHCR.
GHCR_TOKEN=

# --- Deploy tuning -----------------------------------------------------------
STAGING_HEALTH_TIMEOUT_SECONDS=180
STAGING_HEALTH_INTERVAL_SECONDS=5
STAGING_ROLLBACK_ON_FAILURE=true
