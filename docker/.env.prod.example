# Production environment variables for NFM-DB
# Copy to docker/.env.prod and fill in real values

# PostgreSQL
PROD_POSTGRES_USER=nfm
PROD_POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
PROD_POSTGRES_DB=nfm_db
PROD_DB_HOST_PORT=5433

# API
PROD_API_SECRET_KEY=CHANGE_ME_RANDOM_SECRET
PROD_API_HOST_PORT=8001
PROD_CORS_ORIGINS=["https://nucpot.dpdns.org"]
PROD_ACCESS_TOKEN_EXPIRE_MINUTES=30
PROD_IMAGE_TAG=latest

# Worker
PROD_WORKER_CONCURRENCY=1

# Web (Next.js frontend)
PROD_WEB_HOST_PORT=3000

# HPC (Guangzhou Supercomputing)
NFM_HPC_PRIMARY_HOST=
NFM_HPC_PRIMARY_USER=

# Redis
PROD_REDIS_HOST_PORT=6380

# LightRAG sidecar (NFM-1221) — knowledge graph RAG service
PROD_LIGHTRAG_HOST_PORT=9621
PROD_LIGHTRAG_LLM_BINDING=openai
PROD_LIGHTRAG_LLM_MODEL=gpt-4o-mini
PROD_LIGHTRAG_LLM_HOST=https://api.openai.com/v1
PROD_LIGHTRAG_LLM_API_KEY=CHANGE_ME_OPENAI_KEY
PROD_LIGHTRAG_EMBEDDING_BINDING=openai
PROD_LIGHTRAG_EMBEDDING_MODEL=text-embedding-3-small
PROD_LIGHTRAG_EMBEDDING_HOST=https://api.openai.com/v1
PROD_LIGHTRAG_EMBEDDING_API_KEY=CHANGE_ME_OPENAI_KEY
