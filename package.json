{
  "name": "nucpot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "git rev-parse --git-dir > /dev/null 2>&1 && HOOK_DIR=$(git rev-parse --git-dir)/hooks && mkdir -p $HOOK_DIR && cp scripts/pre-push.sh $HOOK_DIR/pre-push && chmod +x $HOOK_DIR/pre-push"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "gray-matter": "^4.0.3",
    "next": "16.2.6",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "playwright": "^1.60.0",
    "puppeteer": "^25.0.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
