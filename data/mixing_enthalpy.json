      "omega_kj_per_mol": -5.0,
      "sign": "exothermic",
      "notes": "Mild exothermic; forms U-Mo solid solution gamma-U(Mo) phase. Consistent with U-10Mo alloy fabrication experience."
    },
    "U-Nb": {
      "element_a": "U",
      "element_b": "Nb",
      "omega_kj_per_mol": -4.0,
