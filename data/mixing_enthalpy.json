    },
    "U-Ti": {
      "element_a": "U",
      "element_b": "Ti",
      "omega_kj_per_mol": 18.0,
      "sign": "endothermic",
      "notes": "Endothermic mixing; limited solubility of Ti in gamma-U. Noted for immiscibility gap at lower temperatures."
    },
    "U-V": {
      "element_a": "U",
      "element_b": "V",
      "omega_kj_per_mol": 20.0,
      "sign": "endothermic",
      "notes": "Strong endothermic; very limited mutual solubility. V acts as hardener/refiner in small amounts."
    },
    "U-Zr": {
      "element_a": "U",
      "element_b": "Zr",
      "omega_kj_per_mol": 6.0,
      "sign": "endothermic",
      "notes": "Mild endothermic; U-Zr forms complex intermetallic phases (UZr2, delta-UZr). Important for U-Zr metallic fuel."
    }
  },
