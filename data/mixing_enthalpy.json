  "_metadata": {
    "description": "Miedema binary mixing enthalpy interaction parameters (Omega_ij) for nuclear fuel alloy design",
    "unit": "kJ/mol",
    "model": "Extended Miedema Model",
    "primary_sources": [
      "de Boer, F.R. et al. (1988). Cohesion in Metals: Transition Metal Alloys. Elsevier.",
      "Takeuchi, A. & Inoue, A. (2005). Classification of Bulk Metallic Glasses by Atomic Size Difference. Mater. Trans., 46(12), 2817-2830.",
      "Miedema, A.R. et al. (1980). Cohesion in Alloys - Fundamentals of a Semi-Empirical Model. Physica B+C, 100(1), 1-28."
    ],
    "note": "Values represent binary interaction parameters Omega_ij used in Delta_H_mix = Sum_{i<j} Omega_ij * x_i * x_j. Negative values indicate exothermic mixing (affinity); positive values indicate endothermic mixing (repulsion). Values are at infinite dilution / equiatomic composition approximation.",
    "generated": "2026-07-19",
    "issue": "NFM-1580",
    "version": "1.0"
  },
